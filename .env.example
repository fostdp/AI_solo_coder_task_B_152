# ============================================
# 古代被中香炉仿真系统 - 环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据需要修改

# ---------- 数据库 ----------
POSTGRES_USER=censer
POSTGRES_PASSWORD=censer123
POSTGRES_DB=censer_simulation
DB_PORT=5432

# ---------- MQTT ----------
MQTT_PORT=1883
MQTT_WS_PORT=9001
MQTT_TOPIC=censer/sensor/#

# ---------- 后端 ----------
BACKEND_PORT=8080
GIN_MODE=release

# ---------- Nginx ----------
NGINX_PORT=80

# ---------- Prometheus ----------
PROM_PORT=9090

# ---------- 模拟器 ----------
SIM_CENSER_CODE=CENSER-001
SIM_MOTION=walking
SIM_INTERVAL=60
